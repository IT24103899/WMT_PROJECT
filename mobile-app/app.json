{
  "expo": {
    "name": "E-Library",
    "slug": "elibrary-mobile",
    "version": "1.0.1",
    "newArchEnabled": true,
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a5f"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e3a5f"
      },
      "package": "com.anonymous.elibrarymobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "ed87f8f0-6c9f-489b-84ad-5544b0cf95b0"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow E-Library to access your camera"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you choose profile pictures and book covers."
        }
      ],
      "expo-document-picker",
      "expo-font"
    ],
    "owner": "thataha"
  }
}
